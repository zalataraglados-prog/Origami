# Production app URL
NEXT_PUBLIC_APP_URL=https://mail.example.com

# GitHub owner 登录（必填）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 可选：限制允许完成首次绑定 / 登录的 GitHub 用户名
GITHUB_ALLOWED_LOGIN=your-github-login

# Session 签名密钥（可选；留空时会回退到 ENCRYPTION_KEY）
AUTH_SECRET=

# Vercel Cron 鉴权密钥（若启用平台定时任务，推荐显式填写）
CRON_SECRET=

# 凭证加密密钥（32 字节的 hex 字符串，64 字符）
# 可用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Turso 数据库（production）
TURSO_DATABASE_URL=libsql://origami-prod-xxx.turso.io
TURSO_AUTH_TOKEN=

# Cloudflare R2（production）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=origami-attachments-prod
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Gmail OAuth (optional default app)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Outlook OAuth (optional default app)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
