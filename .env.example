# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 访问 Token（个人使用，设一个强密码即可）
ACCESS_TOKEN=

# Vercel Cron 鉴权密钥
CRON_SECRET=

# 凭证加密密钥（32 字节的 hex 字符串，64 字符）
# 可用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Turso 数据库
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vtr-box-attachments
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Gmail OAuth (Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Outlook OAuth (Azure AD)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
