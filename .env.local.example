# Local development app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub owner 登录（开发环境）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_LOGIN=your-github-login

AUTH_SECRET=
CRON_SECRET=

# 凭证加密密钥（32 字节的 hex 字符串，64 字符）
ENCRYPTION_KEY=

# Turso 数据库（development）
TURSO_DATABASE_URL=libsql://origami-dev-xxx.turso.io
TURSO_AUTH_TOKEN=

# Cloudflare R2（development）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=origami-attachments-dev
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Gmail OAuth (optional default app)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Outlook OAuth (optional default app)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
